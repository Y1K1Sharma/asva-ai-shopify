{% comment %}
  Asva AI — Product Schema.org JSON-LD app embed.

  Runs in <head> on every storefront page but emits the
  Schema.org/Product structured data ONLY on product pages
  (template == 'product'). This way the JSON-LD lands exactly
  where Google Merchant / Perplexity / ChatGPT / Claude expect
  it, with no per-page configuration from the merchant.

  Implementation note: we built this as a section block first
  (target: "section"), but those didn't register in Horizon's
  Add-section picker. Embeds (target: "head") with a Liquid
  template gate work everywhere — every Shopify theme version,
  every editor surface — and keep the merchant flow uniform
  (one App embeds panel to toggle everything from).

  No settings required — data is pulled from the live `product`
  object so the JSON-LD stays accurate as the catalog changes.
{% endcomment %}

{%- if template == 'product' and product -%}
  {%- assign first_available_variant = product.selected_or_first_available_variant -%}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    {%- if product.featured_image %}
    "image": [
      {%- for image in product.images limit: 5 -%}
      "https:{{ image | image_url: width: 1024 }}"{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    {%- endif %}
    {%- if product.vendor and product.vendor != blank %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    {%- endif %}
    "sku": {{ first_available_variant.sku | json }},
    "url": {{ shop.url | append: product.url | json }},
    "offers": {
      "@type": "Offer",
      "url": {{ shop.url | append: product.url | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": {{ first_available_variant.price | money_without_currency | replace: ',', '' | json }},
      "availability": "{% if first_available_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition"
    }
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Product JSON-LD (Asva AI)",
  "target": "head",
  "settings": [
    {
      "type": "paragraph",
      "content": "Emits Schema.org/Product structured data on every product page in your store. AI agents (ChatGPT, Perplexity, Claude, Gemini) and Google Merchant Center read this to display your products. No setup — data is pulled live from each product."
    }
  ]
}
{% endschema %}
