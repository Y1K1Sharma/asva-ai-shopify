{% comment %}
  Asva AI — Product Schema.org JSON-LD app block.

  Adds Schema.org/Product structured data to product pages so AI shopping
  agents (ChatGPT, Perplexity, Claude, Gemini) can read your catalog
  reliably. Pulls from the live product object, so it stays accurate
  as you edit prices, variants, and availability.

  Compliant with Google's structured-data requirements; supports rich
  results in agent answers.
{% endcomment %}

{%- if product -%}
  {%- assign product_image = product.featured_image | default: product.images[0] -%}
  {%- assign first_available_variant = product.selected_or_first_available_variant -%}

  <script type="application/ld+json">
  {
    "@context": "https://schema.org/",
    "@type": "Product",
    "name": {{ product.title | json }},
    "description": {{ product.description | strip_html | truncate: 500 | json }},
    {%- if product_image %}
    "image": [
      {%- for image in product.images limit: 5 -%}
      "https:{{ image | image_url: width: 1024 }}"{% unless forloop.last %},{% endunless %}
      {%- endfor -%}
    ],
    {%- endif %}
    {%- if product.vendor and product.vendor != blank %}
    "brand": {
      "@type": "Brand",
      "name": {{ product.vendor | json }}
    },
    {%- endif %}
    "sku": {{ first_available_variant.sku | json }},
    "url": {{ shop.url | append: product.url | json }},
    "offers": {
      "@type": "Offer",
      "url": {{ shop.url | append: product.url | json }},
      "priceCurrency": {{ cart.currency.iso_code | json }},
      "price": {{ first_available_variant.price | money_without_currency | replace: ',', '' | json }},
      "availability": "{% if first_available_variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition"
    }
  }
  </script>
{%- endif -%}

{% schema %}
{
  "name": "Product JSON-LD (Asva AI)",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "paragraph",
      "content": "Adds Schema.org/Product structured data to this product page. AI agents need this to display your product in their answers. No configuration required — data is pulled from the product object."
    }
  ]
}
{% endschema %}
